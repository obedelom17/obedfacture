# Une ou plusieurs cles Gemini, separees par des virgules (sans espace autour des virgules).
# Chaque cle = 1 compte Google distinct = son propre quota gratuit quotidien.
# Plus il y a de cles, plus le quota total est eleve (ex: 5 cles x 20/jour = 100/jour).
GEMINI_API_KEYS=cle_du_compte_1,cle_du_compte_2,cle_du_compte_3
